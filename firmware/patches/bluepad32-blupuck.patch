diff --git a/src/components/bluepad32/parser/uni_hid_parser_switch.c b/src/components/bluepad32/parser/uni_hid_parser_switch.c
index 599fc35..b69a66d 100644
--- a/src/components/bluepad32/parser/uni_hid_parser_switch.c
+++ b/src/components/bluepad32/parser/uni_hid_parser_switch.c
@@ -110,6 +110,7 @@ enum switch_subcmd {
     SUBCMD_SET_REPORT_MODE = 0x03,
     SUBCMD_SPI_FLASH_READ = 0x10,
     SUBCMD_SET_PLAYER_LEDS = 0x30,
+    SUBCMD_SET_HOME_LIGHT = 0x38,
     SUBCMD_ENABLE_IMU = 0x40,
 };
 
@@ -1157,7 +1158,13 @@ static void fsm_set_full_report(struct uni_hid_device_s* d) {
     struct switch_subcmd_request* req = (struct switch_subcmd_request*)&out[0];
     req->report_id = 0x01;  // 0x01 for sub commands
     req->subcmd_id = SUBCMD_SET_REPORT_MODE;
-    req->data[0] = 0x30; /* type of report: standard, full */
+    // Local fork patch: select report mode 0x3F (Simple HID, edge-triggered)
+    // instead of 0x30 (Standard, 60 Hz IMU stream). Cuts the Pro Controller's
+    // BT bandwidth from ~23 kbps to near-zero at idle, which lets the Pico W's
+    // CYW43 BT firmware handle 3+ simultaneous Pro Controllers. Trade-off:
+    // no gyro / accel data — the parser's parse_report_3f handler is already
+    // wired in.
+    req->data[0] = 0x3F;
     send_subcmd(d, req, sizeof(out));
 }
 
@@ -1242,6 +1249,27 @@ void uni_hid_parser_switch_set_player_leds(uni_hid_device_t* d, uint8_t leds) {
     set_led(d, leds);
 }
 
+void uni_hid_parser_switch_set_home_led(uni_hid_device_t* d, uint8_t on) {
+    switch_instance_t* ins = get_switch_instance(d);
+    if (ins->state < STATE_READY)
+        return;
+
+    uint8_t out[sizeof(struct switch_subcmd_request) + 4] = {0};
+    struct switch_subcmd_request* req = (struct switch_subcmd_request*)&out[0];
+    req->report_id = 0x01;
+    req->subcmd_id = SUBCMD_SET_HOME_LIGHT;
+    if (on) {
+        // 1 mini cycle, no global duration; full start intensity, infinite
+        // repeat; one mini cycle at full intensity with longest hold.
+        req->data[0] = 0x01;
+        req->data[1] = 0xF0;
+        req->data[2] = 0xF0;
+        req->data[3] = 0xF0;
+    }
+    // else: all zeros = LED off
+    send_subcmd(d, req, sizeof(out));
+}
